#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A Business Rule Task provides a mechanism for the Process to provide input to a Business Rules Engine and to get the output of calculations that the Business Rules Engine might provide."
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A Manual Task is a Task that is expected to be performed without the aid of any business process execution engine or any application. An example of this could be a telephone technician installing a telephone at a customer location."
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A Receive Task is a simple Task that is designed to wait for a Message to arrive from an external Participant (relative to the Process). Once the Message has been received, the Task is completed."
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A Script Task is executed by a business process engine. The modeler or implementer defines a script in a language that the engine can interpret. When the Task is ready to start, the engine will execute the script. When the script is completed, the Task will also be completed."
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A Send Task is a simple Task that is designed to send a Message to an external Participant (relative to the Process). Once the Message has been sent, the Task is completed."
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A Service Task is a Task that uses some sort of service, which could be a Web service or an automated application.  : The Service Task has exactly one set of inputs and at most one set of outputs."
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A Task is an atomic Activity within a Process flow. A Task is used when the work in the Process cannot be broken down to a finer level of detail. Generally, an end-user and/or applications are used to perform the Task when it is executed"
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-SGTasks.json
#. URL: http://smart.who.int/base/CodeSystem-SGTasks.html
#. URL: https://WorldHealthOrganization.github.io/smart-base/CodeSystem-SGTasks.html
#: CodeSystem.concept.definition
msgid "A User Task is a typical “workflow” Task where a human performer performs the Task with the assistance of a software application and is scheduled through a task list manager of some sort."
msgstr ""

#. Source: https://github.com/WorldHealthOrganization/smart-base/blob/main/fsh-generated/resources/CodeSystem-CDSCv2.json
#. URL: http://smart.who.int/base/CodeSystem-CDSCv2.html
