  fhir:version [ fhir:v "0.2.0"] ; # 
  fhir:name [ fhir:v "CDHIv1toCDHIv2"] ; # 
  fhir:title [ fhir:v "Mapping from CDHI v1 to CDISAH v2"] ; # 
  fhir:status [ fhir:v "draft"] ; # 
  fhir:experimental [ fhir:v true] ; # 
  fhir:date [ fhir:v "2026-03-11T20:32:55+00:00"^^xsd:dateTime] ; # 
  fhir:publisher [ fhir:v "WHO"] ; # 
