         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://smart.who.int/base/StructureDefinition/Markdown> ;
         fhir:reference [ fhir:v "StructureDefinition/Markdown" ]
       ] ;
       fhir:name [ fhir:v "Markdown" ] ;
       fhir:description [ fhir:v "Markdown extension" ] ;
       fhir:example [
