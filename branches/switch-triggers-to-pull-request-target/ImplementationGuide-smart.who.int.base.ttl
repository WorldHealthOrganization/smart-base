         fhir:reference [ fhir:v "StructureDefinition/FHIRSchemaBase" ]
       ] ;
       fhir:name [ fhir:v "FHIR Schema Base (SMART Guidelines)" ] ;
       fhir:description [ fhir:v "Base logical model providing the common schema metadata interface inherited by all SMART Guidelines logical models. Every SMART Guidelines logical model schema derives from this base, which documents the shared FHIR and JSON-LD metadata properties used by the JSON Schema generation pipeline." ] ;
