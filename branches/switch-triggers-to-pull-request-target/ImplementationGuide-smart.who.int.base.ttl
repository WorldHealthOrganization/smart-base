         fhir:reference [ fhir:v "StructureDefinition/HealthInterventionsSource" ]
       ] ;
       fhir:name [ fhir:v "Health Interventions Source" ] ;
       fhir:description [ fhir:v "Source reference for Health Interventions - exactly one of the following must be provided:\n- url (url data type): URL to retrieve HealthInterventions definition from input/ or external source\n- canonical (canonical data type): Canonical URI pointing to the HealthInterventions definition\n- instance: Inline HealthInterventions instance data" ] ;
