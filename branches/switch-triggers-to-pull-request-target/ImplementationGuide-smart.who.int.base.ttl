           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://smart.who.int/base/StructureDefinition/BusinessProcessWorkflow> ;
         fhir:reference [ fhir:v "StructureDefinition/BusinessProcessWorkflow" ]
       ] ;
       fhir:name [ fhir:v "Business Process Workflow (DAK)" ] ;
       fhir:description [ fhir:v "Logical Model for representing Generic Business Processes and Workflows from a DAK. A business process is a set of related activities or tasks performed together to achieve the objectives of the health programme area." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
