       fhir:reference [
         fhir:l <http://smart.who.int/base/StructureDefinition/GenericPersona> ;
         fhir:reference [ fhir:v "StructureDefinition/GenericPersona" ]
       ] ;
       fhir:name [ fhir:v "Generic Persona (DAK)" ] ;
       fhir:description [ fhir:v "Logical Model for representing Generic Personas from a DAK. Depiction of the human and system actors. Human actors are end users, supervisors and related stakeholders who would be interacting with the digital system or involved in the clinical care, public health or health system pathway." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
