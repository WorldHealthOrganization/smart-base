         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "ActorDefinition"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://smart.who.int/base/ActorDefinition/DAK.Persona.System.SurveillanceSystem> ;
         fhir:reference [ fhir:v "ActorDefinition/DAK.Persona.System.SurveillanceSystem" ]
       ] ;
       fhir:name [ fhir:v "Public Health and Disease Surveillance System" ] ;
       fhir:description [ fhir:v "A digital system for detecting, monitoring, investigating, and responding to\ndisease outbreaks and public health threats.\n\nThe surveillance system supports DHIs including:\n- Notification of public health events from point of diagnosis (3.3.1)\n- Transmit health event alerts to specific population group(s) (1.1.1)\n- Map location of health event (4.3.2)\n- Data synthesis and visualizations for outbreak response (4.1.3)\n- Automated analysis of data to generate predictions (4.1.4)\n\n**Services and Application Type**: E2 — Public health and disease surveillance systems" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
