           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://smart.who.int/base/StructureDefinition/BusinessProcessWorkflowSource> ;
         fhir:reference [ fhir:v "StructureDefinition/BusinessProcessWorkflowSource" ]
       ] ;
       fhir:name [ fhir:v "Business Process Workflow Source" ] ;
       fhir:description [ fhir:v "Source reference for Business Process Workflow - exactly one of the following must be provided:\n- url (url data type): URL to retrieve BusinessProcessWorkflow definition from input/ or external source\n- canonical (canonical data type): Canonical URI pointing to the BusinessProcessWorkflow definition\n- instance: Inline BusinessProcessWorkflow instance data" ] ;
       fhir:example [
