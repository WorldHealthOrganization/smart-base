  fhir:description [ fhir:v "CodeSystem for the Classification of Digital Health Services and Application Types v2,\nas defined in the Classification of Digital Interventions, Services and Applications in Health\n(CDISAH), second edition (2023). ISBN 978-92-4-008194-9.\n\nServices and Application Types represent the types of software, ICT systems and services\nor communication channels that deliver or execute digital health interventions (DHIs) and\nhealth content.\n\nThe types are organised into five representations within the Digital Health Architecture:\n  A. Point of service\n  B. Health system/Provider administration\n  C. Registries and Directories\n  D. Data Management services\n  E. Surveillance and Response"] ; # 
  fhir:copyright [ fhir:v "WHO © 2023. Some rights reserved. CC BY-NC-SA 3.0 IGO."] ; # 
  fhir:caseSensitive [ fhir:v false] ; # 
  fhir:content [ fhir:v "complete"] ; # 
  fhir:count [ fhir:v "43"^^xsd:nonNegativeInteger] ; # 
  fhir:concept ( [
     fhir:code [ fhir:v "A" ] ;
     fhir:display [ fhir:v "Point of service" ] ;
     fhir:definition [ fhir:v "Systems that facilitate the provision and delivery of healthcare services to persons at the point of care." ]
  ] [
     fhir:code [ fhir:v "A1" ] ;
     fhir:display [ fhir:v "Communication systems" ] ;
     fhir:definition [ fhir:v "Systems that are used to transfer electronic information. Messages can be exchanged between healthcare providers or between healthcare providers and persons." ]
  ] [
     fhir:code [ fhir:v "A2" ] ;
     fhir:display [ fhir:v "Community-based information systems" ] ;
     fhir:definition [ fhir:v "Applications that facilitate data collection and use at the community level, utilised by community-based workers who provide health promotion and disease prevention activities." ]
  ] [
     fhir:code [ fhir:v "A3" ] ;
     fhir:display [ fhir:v "Decision support systems" ] ;
     fhir:definition [ fhir:v "Computer based tools which combine medical information databases and algorithms with patient specific data, intended to provide healthcare professionals and/or users with recommendations for diagnosis, prognosis, monitoring and treatment." ]
  ] [
     fhir:code [ fhir:v "A4" ] ;
     fhir:display [ fhir:v "Diagnostics information systems" ] ;
     fhir:definition [ fhir:v "Systems for diagnostic applications found in devices (software in a medical device), wearables that collect health data, radiology information systems, medical imaging systems, and picture archiving and communication systems (PACS)." ]
  ] [
     fhir:code [ fhir:v "A5" ] ;
     fhir:display [ fhir:v "Electronic medical record systems" ] ;
     fhir:definition [ fhir:v "A secure, online system that holds information about people's health and clinical care, managed by healthcare providers. Also known as electronic health record (EHR)." ]
  ] [
     fhir:code [ fhir:v "A6" ] ;
     fhir:display [ fhir:v "Laboratory information systems" ] ;
     fhir:definition [ fhir:v "Systems that support the process from patient sample to patient result, including lab requests/test ordering, sample tracking and processing, and results reporting." ]
  ] [
     fhir:code [ fhir:v "A7" ] ;
     fhir:display [ fhir:v "Personal health records" ] ;
     fhir:definition [ fhir:v "A digital personal health record is a record of an individual's health information in a structured digital format, over which the person has agency." ]
  ] [
     fhir:code [ fhir:v "A8" ] ;
     fhir:display [ fhir:v "Pharmacy information systems" ] ;
     fhir:definition [ fhir:v "Systems that manage prescriptions, dispensing, stock and billing for medicines and health products." ]
  ] [
     fhir:code [ fhir:v "A9" ] ;
     fhir:display [ fhir:v "Telehealth systems" ] ;
     fhir:definition [ fhir:v "Systems that enable remote clinical consultation, monitoring and diagnosis between persons and healthcare providers at a distance." ]
  ] [
     fhir:code [ fhir:v "B" ] ;
     fhir:display [ fhir:v "Health system/Provider administration" ] ;
     fhir:definition [ fhir:v "Systems that support the administrative and managerial functions of health systems and healthcare organisations." ]
  ] [
     fhir:code [ fhir:v "B1" ] ;
     fhir:display [ fhir:v "Blood bank information management systems" ] ;
     fhir:definition [ fhir:v "Systems for managing the collection, testing, processing, storage, and distribution of blood and blood products." ]
  ] [
     fhir:code [ fhir:v "B2" ] ;
     fhir:display [ fhir:v "Health finance-related information systems" ] ;
     fhir:definition [ fhir:v "Systems that manage health financing, insurance enrolment, claims, billing, reimbursement, and budgeting." ]
  ] [
     fhir:code [ fhir:v "B3" ] ;
     fhir:display [ fhir:v "Health program monitoring systems" ] ;
     fhir:definition [ fhir:v "Systems used to collect and analyse aggregate health data for programme planning, monitoring and evaluation." ]
  ] [
     fhir:code [ fhir:v "B4" ] ;
     fhir:display [ fhir:v "Human resource information systems" ] ;
     fhir:definition [ fhir:v "Systems for managing health workforce data including cadres, deployment, credentials, performance and payroll." ]
  ] [
     fhir:code [ fhir:v "B5" ] ;
     fhir:display [ fhir:v "Learning and training systems" ] ;
     fhir:definition [ fhir:v "Systems for delivering, tracking, and assessing training and professional development of health workers." ]
  ] [
     fhir:code [ fhir:v "B6" ] ;
     fhir:display [ fhir:v "Logistics management information systems (LMIS)" ] ;
     fhir:definition [ fhir:v "Systems for managing the health supply chain from forecasting to distribution and stock monitoring." ]
  ] [
     fhir:code [ fhir:v "B7" ] ;
     fhir:display [ fhir:v "Patient Administration systems" ] ;
     fhir:definition [ fhir:v "Systems that manage patient administrative information including admissions, discharges, transfers, appointments and billing." ]
  ] [
     fhir:code [ fhir:v "B8" ] ;
     fhir:display [ fhir:v "Research information systems" ] ;
     fhir:definition [ fhir:v "Systems that support the design, conduct, data management and reporting of health research and clinical trials." ]
  ] [
     fhir:code [ fhir:v "C" ] ;
     fhir:display [ fhir:v "Registries and Directories" ] ;
     fhir:definition [ fhir:v "Systems that create, maintain, and provide authoritative master records for persons, providers, facilities, products and health events." ]
  ] [
     fhir:code [ fhir:v "C1" ] ;
     fhir:display [ fhir:v "Census and population information systems" ] ;
     fhir:definition [ fhir:v "Systems that collect, store, and manage population-level demographic data including census information." ]
  ] [
     fhir:code [ fhir:v "C2" ] ;
     fhir:display [ fhir:v "Civil registration and vital statistics (CRVS) systems" ] ;
     fhir:definition [ fhir:v "Systems that register and certify vital events such as births, deaths, marriages and their underlying causes." ]
  ] [
     fhir:code [ fhir:v "C3" ] ;
     fhir:display [ fhir:v "Facility management information systems" ] ;
     fhir:definition [ fhir:v "Systems for managing health facility information, infrastructure, equipment, capacity and assessments." ]
  ] [
     fhir:code [ fhir:v "C4" ] ;
     fhir:display [ fhir:v "(Health) Facility registries" ] ;
     fhir:definition [ fhir:v "Master lists of health facilities with unique identifiers, locations, services offered, and operational information." ]
  ] [
     fhir:code [ fhir:v "C5" ] ;
     fhir:display [ fhir:v "Health worker registry" ] ;
     fhir:definition [ fhir:v "Systems maintaining authoritative directories of health workforce cadres, credentials, and deployment information." ]
  ] [
     fhir:code [ fhir:v "C6" ] ;
     fhir:display [ fhir:v "Identification registries and directories" ] ;
     fhir:definition [ fhir:v "Systems that create, maintain, and verify unique identities for persons, healthcare providers, and other health actors." ]
  ] [
     fhir:code [ fhir:v "C7" ] ;
     fhir:display [ fhir:v "Immunization information systems" ] ;
     fhir:definition [ fhir:v "Systems for recording, tracking, and reporting individual and population-level immunization history and coverage." ]
  ] [
     fhir:code [ fhir:v "C8" ] ;
     fhir:display [ fhir:v "Master patient index" ] ;
     fhir:definition [ fhir:v "Systems that uniquely identify and link patient records across multiple health information systems and facilities." ]
  ] [
     fhir:code [ fhir:v "C9" ] ;
     fhir:display [ fhir:v "Product catalogues" ] ;
     fhir:definition [ fhir:v "Systems that maintain authoritative lists of approved health commodities, medicines, devices and equipment." ]
  ] [
     fhir:code [ fhir:v "C10" ] ;
     fhir:display [ fhir:v "Public Key directories" ] ;
     fhir:definition [ fhir:v "Systems that manage and distribute public cryptographic keys to support digital signature and identity verification." ]
  ] [
     fhir:code [ fhir:v "C11" ] ;
     fhir:display [ fhir:v "Terminology and classification systems" ] ;
     fhir:definition [ fhir:v "Systems for managing and applying standardised clinical terminologies, ontologies, and health classifications." ]
  ] [
     fhir:code [ fhir:v "D" ] ;
     fhir:display [ fhir:v "Data Management services" ] ;
     fhir:definition [ fhir:v "Services and systems that support the collection, aggregation, storage, analysis, and exchange of health data." ]
  ] [
     fhir:code [ fhir:v "D1" ] ;
     fhir:display [ fhir:v "Analytics Systems" ] ;
     fhir:definition [ fhir:v "Systems that process and analyse health data to produce insights, dashboards, reports and predictive models." ]
  ] [
     fhir:code [ fhir:v "D2" ] ;
     fhir:display [ fhir:v "Data interchange and interoperability" ] ;
     fhir:definition [ fhir:v "Systems and standards that enable health data exchange between disparate systems, including APIs, messaging standards, and interoperability platforms." ]
  ] [
     fhir:code [ fhir:v "D3" ] ;
     fhir:display [ fhir:v "Data warehouses" ] ;
     fhir:definition [ fhir:v "Systems that consolidate and store large volumes of historical health data from multiple sources for analysis and reporting." ]
  ] [
     fhir:code [ fhir:v "D4" ] ;
     fhir:display [ fhir:v "Environmental monitoring systems" ] ;
     fhir:definition [ fhir:v "Systems that monitor environmental determinants of health such as air quality, water safety and vector habitats." ]
  ] [
     fhir:code [ fhir:v "D5" ] ;
     fhir:display [ fhir:v "Geographic information systems (GIS)" ] ;
     fhir:definition [ fhir:v "Systems that capture, analyse and visualise geospatial health data for mapping health events, facilities, and populations." ]
  ] [
     fhir:code [ fhir:v "D6" ] ;
     fhir:display [ fhir:v "Health Management Information systems (HMIS)" ] ;
     fhir:definition [ fhir:v "Systems for aggregate health data reporting, target-setting, and programme monitoring, typically at district and national levels." ]
  ] [
     fhir:code [ fhir:v "D7" ] ;
     fhir:display [ fhir:v "Knowledge management systems" ] ;
     fhir:definition [ fhir:v "Systems for curating, organising and disseminating clinical guidelines, protocols, and health knowledge resources." ]
  ] [
     fhir:code [ fhir:v "D8" ] ;
     fhir:display [ fhir:v "Shared Health Record and Health Information Repository" ] ;
     fhir:definition [ fhir:v "Systems that aggregate and share longitudinal health records across facilities and providers." ]
  ] [
     fhir:code [ fhir:v "E" ] ;
     fhir:display [ fhir:v "Surveillance and Response" ] ;
     fhir:definition [ fhir:v "Systems that support the detection, monitoring, and response to disease outbreaks and public health threats." ]
  ] [
     fhir:code [ fhir:v "E1" ] ;
     fhir:display [ fhir:v "Emergency preparedness and response systems" ] ;
     fhir:definition [ fhir:v "Systems that coordinate emergency medical services, disaster preparedness, and mass casualty management." ]
  ] [
     fhir:code [ fhir:v "E2" ] ;
     fhir:display [ fhir:v "Public health and disease surveillance systems" ] ;
     fhir:definition [ fhir:v "Systems for detecting, monitoring, investigating and responding to disease outbreaks and public health threats." ]
  ] ) . # 

